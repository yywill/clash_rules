# Shadowrocket AI ruleset (cleaned from AI.list)
# - No PROCESS-NAME (unsupported on iOS Shadowrocket)
# - No overly broad Google/analytics catch-alls that would steal global traffic
# 内容：OpenAI / Claude / Gemini / Copilot / Meta AI / Perplexity / Cursor 等

# 域名关键字匹配
DOMAIN-KEYWORD,openai
DOMAIN-KEYWORD,anthropic
DOMAIN-KEYWORD,claude
DOMAIN-KEYWORD,copilot
DOMAIN-KEYWORD,grazie
DOMAIN-KEYWORD,openaicom
DOMAIN-KEYWORD,notebooklm
DOMAIN-KEYWORD,perplexity
DOMAIN-KEYWORD,antigravity

