# 进程名匹配 (Process name) — Surge 专用：空格用 %20 编码，支持通配符 * ?
# Antigravity AI 语言服务进程
PROCESS-NAME,language_server
# Antigravity Helper（含 GPU/Plugin/Renderer 子进程）
PROCESS-NAME,Antigravity%20Helper*
# Claude Code CLI：可执行文件以版本号命名(~/.local/share/claude/versions/<version>)
# 用完整路径通配匹配，避免版本升级后失效
PROCESS-NAME,*/claude/versions/*
# ChatGPT 桌面 App
PROCESS-NAME,ChatGPT
